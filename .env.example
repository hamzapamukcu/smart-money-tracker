# Database
DATABASE_URL=sqlite:///data/tracker.db
# Switch to this for cloud:
# DATABASE_URL=postgresql://user:password@host:5432/smartmoney

# SEC EDGAR (required — SEC rejects requests without User-Agent)
SEC_USER_AGENT=YourName youremail@example.com

# Optional: email alerts
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Streamlit
STREAMLIT_SERVER_PORT=8501
